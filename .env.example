# Clank&Claw MVP Environment Variables

# ============================================================================
# REQUIRED: Deployer Wallet Configuration
# ============================================================================
# Private key for signing deployment transactions (keep secure!)
DEPLOYER_SIGNER_PRIVATE_KEY=0x...

# Token admin address (manages token metadata and rewards)
TOKEN_ADMIN_ADDRESS=0x...

# Fee recipient address (receives trading fees)
FEE_RECIPIENT_ADDRESS=0x...

# ============================================================================
# REQUIRED: Telegram Bot Configuration
# ============================================================================
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=...

# Your Telegram chat ID (use @userinfobot to get it)
TELEGRAM_CHAT_ID=...
# For forum supergroup/topic routing, this must be the supergroup ID (usually starts with -100...).

# Optional: target a specific forum topic/thread in the chat
# TELEGRAM_MESSAGE_THREAD_ID=123

# Optional: per-category thread routing (forum topic IDs)
# If unset, bot falls back to TELEGRAM_MESSAGE_THREAD_ID (or latest operator thread).
# TELEGRAM_THREAD_REVIEW_ID=201
# TELEGRAM_THREAD_DEPLOY_ID=202
# TELEGRAM_THREAD_CLAIM_ID=203
# TELEGRAM_THREAD_OPS_ID=204
# TELEGRAM_THREAD_ALERT_ID=205

# ============================================================================
# REQUIRED: Pinata IPFS Configuration
# ============================================================================
# Get JWT from Pinata dashboard (https://pinata.cloud)
PINATA_JWT=...

# ============================================================================
# REQUIRED: Base RPC and Clanker SDK Configuration
# ============================================================================
# Preferred: Alchemy Base mainnet RPC (used with highest priority by config loader)
ALCHEMY_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/<YOUR_KEY>

# Backward-compatible fallback if Alchemy var is unset
# BASE_RPC_URL=https://mainnet.base.org

# Optional: override path to node_modules containing clanker-sdk and viem
# Default: ./node_modules (this project)
# CLANKER_NODE_MODULES_PATH=/path/to/node_modules
# Optional: override clanker-sdk CLI path (used by /claimfees)
# CLANKER_CLI_PATH=/path/to/node_modules/.bin/clanker-sdk

# Optional: override path to clanker_deploy.mjs script
# Defaults to scripts/clanker_deploy.mjs in this project
# NODE_SCRIPT_PATH=/path/to/clanker_deploy.mjs

# Optional: Pinata dedupe cache path (content hash -> CID)
# PINATA_CACHE_PATH=.pinata_cache.json
# Optional: cap local Pinata cache size and flush cadence
# PINATA_CACHE_MAX_ENTRIES=20000
# PINATA_CACHE_FLUSH_EVERY=25

# Optional: DB retention cleanup loop (24/7 hygiene)
# APP_CLEANUP_ENABLED=true
# APP_CLEANUP_INTERVAL_SECONDS=900
# APP_RETENTION_CANDIDATES_DAYS=3
# APP_RETENTION_REVIEWS_DAYS=7
# APP_RETENTION_DEPLOYMENTS_DAYS=14
# APP_RETENTION_REWARDS_DAYS=30

# ============================================================================
# OPTIONAL: X/Twitter Configuration
# ============================================================================
# No API keys needed for twscrape - it uses authenticated accounts
# Configure accounts using: twscrape add_account <name> <user> <pass> <email> <email_pass>
# See QUICKSTART.md for setup instructions

# ============================================================================
# OPTIONAL: Farcaster / Neynar Configuration
# ============================================================================
# Required if farcaster_detector.enabled=true
# Get API key from https://docs.neynar.com/
# NEYNAR_API_KEY=...

# ============================================================================
# OPTIONAL: Gemini LLM Cost Guard (24/7 Safety)
# ============================================================================
# Enable/disable all Gemini calls globally.
# GEMINI_ENABLED=true
# Preferred model override (if empty, runtime uses flash-lite -> flash fallback).
# GEMINI_MODEL=models/gemini-2.5-flash-lite
# Hard daily request cap (UTC day). Calls beyond this are skipped safely.
# GEMINI_DAILY_REQUEST_LIMIT=12000

# ============================================================================
# OPTIONAL: GeckoTerminal Detector Tuning
# ============================================================================
# Networks are configured in config.yaml (base, eth, solana, bsc).
# GeckoTerminal public API is used via:
# https://api.geckoterminal.com/api/v2/networks/<network>/new_pools?page=1

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit this file with real values to git
# 2. Keep private keys secure and never share them
# 3. Use separate wallets for different roles (signer, admin, recipient)
# 4. Fund deployer wallet with ETH for gas fees
# 5. Test on Base testnet before mainnet deployment
# 6. See DEPLOYMENT.md for detailed setup instructions
# 7. See docs/CLANKER_INTEGRATION.md for Clanker-specific configuration
